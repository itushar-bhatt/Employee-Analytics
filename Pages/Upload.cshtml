@page
@model EmployeeDashboard.Pages.UploadModel

<h2>Upload CSV</h2>

<form method="post" enctype="multipart/form-data">

    <div class="mb-3">
        <input type="file" asp-for="CsvFile" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Upload
    </button>

</form>

@if (Model.Message != "")
{
    <div class="alert alert-success mt-3">
        @Model.Message
    </div>
}